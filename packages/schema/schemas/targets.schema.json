{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://msvg.dev/schemas/targets.schema.json",
  "title": "MsvgTargets",
  "description": "Maps logical camelCase target names to SVG selectors (motion/targets.json). See Spec Section 9.",
  "type": "object",
  "propertyNames": {
    "pattern": "^[a-z][a-zA-Z0-9]*$",
    "description": "Target names should be camelCase (Section 32.2)."
  },
  "additionalProperties": {
    "$ref": "#/$defs/target"
  },
  "$defs": {
    "target": {
      "oneOf": [
        {
          "type": "string",
          "description": "A CSS selector. The runtime animates every match."
        },
        {
          "type": "object",
          "required": ["selector"],
          "additionalProperties": false,
          "properties": {
            "selector": { "type": "string" },
            "expect": {
              "type": "string",
              "enum": ["one", "many"],
              "description": "Cardinality expectation (Section 9.3)."
            }
          }
        }
      ]
    }
  }
}
