{
  "schemaVersion": "1.0",
  "id": "inventory-agent",
  "name": "Inventory Agent",
  "version": "0.1.0",
  "description": "Animated SVG assistant for inventory monitoring states.",

  "asset": {
    "svg": "./assets/main.svg",
    "preview": "./assets/preview.png"
  },

  "motion": {
    "targets": "./motion/targets.json",
    "timelines": "./motion/timelines.json",
