    "idleCss": "./motion/idle.css"
  },

  "accessibility": {
    "title": "Inventory Agent",
    "description": "Animated assistant representing inventory monitoring.",
    "decorative": false
  },

  "reducedMotion": {
    "strategy": "static",
    "fallbackState": "idle"
  }
}
