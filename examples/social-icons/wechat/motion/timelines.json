{
  "intro": [
    {
      "target": "glyph",
      "at": 0,
      "keyframes": [
        { "opacity": 0, "transform": "translateY(3px) scale(0.94)" },
        { "opacity": 1, "transform": "translateY(-1px) scale(1)", "offset": 0.72 },
        { "opacity": 1, "transform": "translateY(0px) scale(1)" }
      ],
      "options": { "duration": 480, "easing": "soft", "fill": "both" }
    }
  ],
  "loadingLoop": [
    {
      "target": "bubbleBig",
      "at": 0,
      "keyframes": [
        { "transform": "scale(1)", "offset": 0, "easing": "soft" },
        { "transform": "scale(1.08)", "offset": 0.12, "easing": "soft" },
        { "transform": "scale(1)", "offset": 0.24, "easing": "linear" },
        { "transform": "scale(1)", "offset": 1 }
      ],
      "options": { "duration": 2600, "easing": "linear", "fill": "both" }
    },
    {
      "target": "bubbleSmall",
      "at": 0,
      "keyframes": [
        { "transform": "scale(1)", "offset": 0, "easing": "linear" },
        { "transform": "scale(1)", "offset": 0.38, "easing": "soft" },
        { "transform": "scale(1.12)", "offset": 0.5, "easing": "soft" },
        { "transform": "scale(1)", "offset": 0.62, "easing": "linear" },
        { "transform": "scale(1)", "offset": 1 }
      ],
      "options": { "duration": 2600, "easing": "linear", "fill": "both" }
    }
  ],
  "hover": [
    {
      "target": "bubbleBig",
      "at": 0,
      "keyframes": [
        { "transform": "scale(1)", "offset": 0, "easing": "soft" },
        { "transform": "scale(1.08)", "offset": 0.2, "easing": "soft" },
        { "transform": "scale(1)", "offset": 0.4, "easing": "linear" },
        { "transform": "scale(1)", "offset": 1 }
      ],
      "options": { "duration": 900, "easing": "linear", "fill": "both" }
    },
    {
      "target": "bubbleSmall",
      "at": 0,
      "keyframes": [
        { "transform": "scale(1)", "offset": 0, "easing": "linear" },
        { "transform": "scale(1)", "offset": 0.45, "easing": "soft" },
        { "transform": "scale(1.12)", "offset": 0.65, "easing": "soft" },
        { "transform": "scale(1)", "offset": 0.85, "easing": "linear" },
        { "transform": "scale(1)", "offset": 1 }
      ],
      "options": { "duration": 900, "easing": "linear", "fill": "both" }
    }
  ]
}
