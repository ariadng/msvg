{
  "intro": [
    {
      "target": "glyph",
      "at": 0,
      "keyframes": [
        { "opacity": 0, "transform": "scale(0.82)" },
        { "opacity": 1, "transform": "scale(1.06)", "offset": 0.65 },
        { "opacity": 1, "transform": "scale(1)" }
      ],
      "options": { "duration": 460, "easing": "bounceSoft", "fill": "both" }
    }
  ],
  "loadingLoop": [
    {
      "target": "glyph",
      "at": 0,
      "keyframes": [
        { "transform": "scale(1)", "offset": 0, "easing": "emphasized" },
        { "transform": "scale(1.09)", "offset": 0.04, "easing": "soft" },
        { "transform": "scale(1)", "offset": 0.19, "easing": "linear" },
        { "transform": "scale(1)", "offset": 0.25, "easing": "emphasized" },
        { "transform": "scale(1.09)", "offset": 0.29, "easing": "soft" },
        { "transform": "scale(1)", "offset": 0.44, "easing": "linear" },
        { "transform": "scale(1)", "offset": 1 }
      ],
      "options": { "duration": 2000, "easing": "linear", "fill": "both" }
    }
  ],
  "hover": [
    {
      "target": "glyph",
      "at": 0,
      "keyframes": [
        { "transform": "scale(1)", "offset": 0, "easing": "emphasized" },
        { "transform": "scale(1.09)", "offset": 0.17, "easing": "soft" },
        { "transform": "scale(1)", "offset": 1, "easing": "linear" }
      ],
      "options": { "duration": 460, "easing": "linear", "fill": "both" }
    }
  ]
}
