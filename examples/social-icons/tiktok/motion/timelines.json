{
  "intro": [
    {
      "target": "glyph",
      "at": 0,
      "keyframes": [
        { "opacity": 0, "transform": "scale(0.82)" },
        { "opacity": 1, "transform": "scale(1.06)", "offset": 0.65 },
        { "opacity": 1, "transform": "scale(1)" }
      ],
      "options": { "duration": 460, "easing": "bounceSoft", "fill": "both" }
    }
  ],
  "loadingLoop": [
    {
      "target": "glyph",
      "at": 0,
      "keyframes": [
        { "transform": "scale(1)", "offset": 0, "easing": "emphasized" },
        { "transform": "scale(1.08)", "offset": 0.12, "easing": "soft" },
        { "transform": "scale(1)", "offset": 0.26, "easing": "emphasized" },
        { "transform": "scale(1.05)", "offset": 0.36, "easing": "soft" },
        { "transform": "scale(1)", "offset": 0.5, "easing": "soft" },
        { "transform": "scale(1)", "offset": 1 }
      ],
      "options": { "duration": 1500, "easing": "soft", "fill": "both" }
    }
  ],
  "hover": [
    {
      "target": "glyph",
      "at": 0,
      "keyframes": [
        { "transform": "scale(1)" },
        { "transform": "scale(1.08)", "offset": 0.4 },
        { "transform": "scale(1)" }
      ],
      "options": { "duration": 420, "easing": "bounceSoft", "fill": "both" }
    }
  ]
}
