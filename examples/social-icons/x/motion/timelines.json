{
  "intro": [
    {
      "target": "glyph",
      "at": 0,
      "keyframes": [
        { "opacity": 0, "transform": "scale(0.9) rotate(-6deg)" },
        { "opacity": 1, "transform": "scale(1.03) rotate(2deg)", "offset": 0.7 },
        { "opacity": 1, "transform": "scale(1) rotate(0deg)" }
      ],
      "options": { "duration": 420, "easing": "emphasized", "fill": "both" }
    }
  ],
  "loadingLoop": [
    {
      "target": "glyph",
      "at": 0,
      "keyframes": [
        { "transform": "scale(1)", "offset": 0, "easing": "emphasized" },
        { "transform": "scale(1.06)", "offset": 0.05, "easing": "linear" },
        { "transform": "scale(1.06)", "offset": 0.12, "easing": "standard" },
        { "transform": "scale(1)", "offset": 0.18, "easing": "linear" },
        { "transform": "scale(1)", "offset": 1 }
      ],
      "options": { "duration": 2400, "easing": "linear", "fill": "both" }
    }
  ],
  "hover": [
    {
      "target": "glyph",
      "at": 0,
      "keyframes": [
        { "transform": "scale(1)", "offset": 0, "easing": "emphasized" },
        { "transform": "scale(1.06)", "offset": 0.2, "easing": "linear" },
        { "transform": "scale(1.06)", "offset": 0.4, "easing": "standard" },
        { "transform": "scale(1)", "offset": 0.75, "easing": "linear" },
        { "transform": "scale(1)", "offset": 1 }
      ],
      "options": { "duration": 520, "easing": "linear", "fill": "both" }
    }
  ]
}
