{
  "intro": [
    {
      "target": "glyph",
      "at": 0,
      "keyframes": [
        { "opacity": 0, "transform": "scale(0.84)" },
        { "opacity": 1, "transform": "scale(1.04)", "offset": 0.7, "easing": "soft" },
        { "opacity": 1, "transform": "scale(1)" }
      ],
      "options": { "duration": 460, "easing": "emphasized", "fill": "both" }
    }
  ],
  "loadingLoop": [
    {
      "target": "glyph",
      "at": 0,
      "keyframes": [
        { "transform": "rotate(0deg)", "offset": 0, "easing": "linear" },
        { "transform": "rotate(-5deg)", "offset": 0.025, "easing": "linear" },
        { "transform": "rotate(5deg)", "offset": 0.05, "easing": "linear" },
        { "transform": "rotate(-5deg)", "offset": 0.075, "easing": "linear" },
        { "transform": "rotate(0deg)", "offset": 0.1, "easing": "linear" },
        { "transform": "rotate(0deg)", "offset": 0.158, "easing": "linear" },
        { "transform": "rotate(-5deg)", "offset": 0.183, "easing": "linear" },
        { "transform": "rotate(5deg)", "offset": 0.208, "easing": "linear" },
        { "transform": "rotate(-5deg)", "offset": 0.233, "easing": "linear" },
        { "transform": "rotate(0deg)", "offset": 0.258, "easing": "linear" },
        { "transform": "rotate(0deg)", "offset": 1 }
      ],
      "options": { "duration": 2400, "easing": "linear", "fill": "both" }
    }
  ],
  "hover": [
    {
      "target": "glyph",
      "at": 0,
      "keyframes": [
        { "transform": "rotate(0deg)", "offset": 0, "easing": "linear" },
        { "transform": "rotate(-5deg)", "offset": 0.25, "easing": "linear" },
        { "transform": "rotate(5deg)", "offset": 0.5, "easing": "linear" },
        { "transform": "rotate(-5deg)", "offset": 0.75, "easing": "linear" },
        { "transform": "rotate(0deg)", "offset": 1 }
      ],
      "options": { "duration": 360, "easing": "linear", "fill": "both" }
    }
  ]
}
