{
  "intro": [
    {
      "target": "glyph",
      "at": 0,
      "keyframes": [
        { "opacity": 0, "transform": "scale(0.84) rotate(-6deg)" },
        { "opacity": 1, "transform": "scale(1.03) rotate(1deg)", "offset": 0.72, "easing": "soft" },
        { "opacity": 1, "transform": "scale(1) rotate(0deg)" }
      ],
      "options": { "duration": 480, "easing": "emphasized", "fill": "both" }
    }
  ],
  "loadingLoop": [
    {
      "target": "glyph",
      "at": 0,
      "keyframes": [
        { "transform": "rotate(0deg)", "opacity": 1, "offset": 0, "easing": "soft" },
        { "transform": "rotate(-4deg)", "opacity": 1, "offset": 0.1, "easing": "soft" },
        { "transform": "rotate(3deg)", "opacity": 0.45, "offset": 0.2, "easing": "standard" },
        { "transform": "rotate(-1.5deg)", "opacity": 1, "offset": 0.32, "easing": "soft" },
        { "transform": "rotate(0deg)", "opacity": 1, "offset": 0.44, "easing": "soft" },
        { "transform": "rotate(0deg)", "opacity": 1, "offset": 1 }
      ],
      "options": { "duration": 2100, "easing": "soft", "fill": "both" }
    }
  ],
  "hover": [
    {
      "target": "glyph",
      "at": 0,
      "keyframes": [
        { "transform": "rotate(0deg)", "opacity": 1 },
        { "transform": "rotate(3deg)", "opacity": 0.5, "offset": 0.4, "easing": "standard" },
        { "transform": "rotate(0deg)", "opacity": 1, "easing": "soft" }
      ],
      "options": { "duration": 420, "easing": "soft", "fill": "both" }
    }
  ]
}
