{
  "intro": [
    {
      "target": "glyph",
      "at": 0,
      "keyframes": [
        { "opacity": 0, "transform": "translateY(-14px) scale(0.96)" },
        { "opacity": 1, "transform": "translateY(0px) scale(1)" }
      ],
      "options": {
        "duration": 400,
        "easing": "standard",
        "fill": "both"
      }
    }
  ],
  "hover": [
    {
      "target": "glyph",
      "at": 0,
      "keyframes": [
        { "transform": "scale(1)" },
        { "transform": "scale(1.05)" }
      ],
      "options": {
        "duration": 200,
        "easing": "soft",
        "fill": "both"
      }
    }
  ],
  "loadingLoop": [
    {
      "target": "barTop",
      "at": 0,
      "keyframes": [
        { "transform": "translateX(0px)", "offset": 0, "easing": "linear" },
        { "transform": "translateX(0px)", "offset": 0.02, "easing": "standard" },
        { "transform": "translateX(50px)", "offset": 0.11, "easing": "soft" },
        { "transform": "translateX(0px)", "offset": 0.2, "easing": "linear" },
        { "transform": "translateX(0px)", "offset": 1 }
      ],
      "options": {
        "duration": 2400,
        "easing": "linear",
        "fill": "both"
      }
    },
    {
      "target": "barMiddle",
      "at": 0,
      "keyframes": [
        { "transform": "translateX(0px)", "offset": 0, "easing": "linear" },
        { "transform": "translateX(0px)", "offset": 0.07, "easing": "standard" },
        { "transform": "translateX(50px)", "offset": 0.16, "easing": "soft" },
        { "transform": "translateX(0px)", "offset": 0.25, "easing": "linear" },
        { "transform": "translateX(0px)", "offset": 1 }
      ],
      "options": {
        "duration": 2400,
        "easing": "linear",
        "fill": "both"
      }
    },
    {
      "target": "barBottom",
      "at": 0,
      "keyframes": [
        { "transform": "translateX(0px)", "offset": 0, "easing": "linear" },
        { "transform": "translateX(0px)", "offset": 0.12, "easing": "standard" },
        { "transform": "translateX(50px)", "offset": 0.21, "easing": "soft" },
        { "transform": "translateX(0px)", "offset": 0.3, "easing": "linear" },
        { "transform": "translateX(0px)", "offset": 1 }
      ],
      "options": {
        "duration": 2400,
        "easing": "linear",
        "fill": "both"
      }
    }
  ]
}
