{
  "intro": [
    {
      "target": "glyph",
      "at": 0,
      "keyframes": [
        {
          "opacity": 0,
          "transform": "scale(0.85) rotate(-12deg)"
        },
        {
          "opacity": 1,
          "transform": "scale(1) rotate(0deg)"
        }
      ],
      "options": {
        "duration": 420,
        "easing": "emphasized",
        "fill": "both"
      }
    }
  ],
  "hover": [
    {
      "target": "glyph",
      "at": 0,
      "keyframes": [
        {
          "transform": "scale(1)"
        },
        {
          "transform": "scale(1.08)"
        }
      ],
      "options": {
        "duration": 200,
        "easing": "soft",
        "fill": "both"
      }
    }
  ],
  "loadingLoop": [
    {
      "target": "glyph",
      "at": 0,
      "keyframes": [
        {
          "transform": "translateX(0px) rotate(0deg)",
          "offset": 0,
          "easing": "cubic-bezier(.37, 0, .63, 1)"
        },
        {
          "transform": "translateX(90px) rotate(6deg)",
          "offset": 0.46,
          "easing": "soft"
        },
        {
          "transform": "translateX(0px) rotate(0deg)",
          "offset": 0.6,
          "easing": "linear"
        },
        {
          "transform": "translateX(0px) rotate(0deg)",
          "offset": 1
        }
      ],
      "options": {
        "duration": 2400,
        "easing": "linear",
        "fill": "both"
      }
    }
  ]
}