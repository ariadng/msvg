{
  "intro": [
    {
      "target": "glyph",
      "at": 0,
      "keyframes": [
        { "opacity": 0, "transform": "translateY(-14px) scale(0.94)" },
        { "opacity": 1, "transform": "translateY(0) scale(1)" }
      ],
      "options": { "duration": 450, "easing": "standard", "fill": "both" }
    }
  ],

  "loadingLoop": [
    {
      "target": "can",
      "at": 0,
      "keyframes": [
        { "offset": 0,    "transform": "rotate(0deg)",   "easing": "soft" },
        { "offset": 0.24, "transform": "rotate(-14deg)", "easing": "linear" },
        { "offset": 0.44, "transform": "rotate(-14deg)", "easing": "soft" },
        { "offset": 0.62, "transform": "rotate(0deg)",   "easing": "linear" },
        { "offset": 1,    "transform": "rotate(0deg)" }
      ],
      "options": { "duration": 2600, "easing": "linear", "fill": "both" }
    }
  ],

  "hover": [
    {
      "target": "can",
      "at": 0,
      "keyframes": [
        { "offset": 0,    "transform": "rotate(0deg)",   "easing": "soft" },
        { "offset": 0.50, "transform": "rotate(-12deg)", "easing": "soft" },
        { "offset": 1,    "transform": "rotate(0deg)" }
      ],
      "options": { "duration": 360, "easing": "linear", "fill": "both" }
    }
  ]
}
