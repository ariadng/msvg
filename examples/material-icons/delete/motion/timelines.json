{
  "intro": [
    {
      "target": "glyph",
      "at": 0,
      "keyframes": [
        { "opacity": 0, "transform": "translateY(-14px) scale(0.94)" },
        { "opacity": 1, "transform": "translateY(0) scale(1)" }
      ],
      "options": { "duration": 450, "easing": "standard", "fill": "both" }
    }
  ],

  "loadingLoop": [
    {
      "target": "glyph",
      "at": 0,
      "keyframes": [
        { "offset": 0, "transform": "rotate(0deg)" },
        { "offset": 0.25, "transform": "rotate(-6deg)" },
        { "offset": 0.5, "transform": "rotate(0deg)" },
        { "offset": 0.75, "transform": "rotate(6deg)" },
        { "offset": 1, "transform": "rotate(0deg)" }
      ],
      "options": { "duration": 2400, "easing": "soft", "fill": "both" }
    }
  ],

  "hover": [
    {
      "target": "glyph",
      "at": 0,
      "keyframes": [
        { "transform": "rotate(0deg)" },
        { "transform": "rotate(-6deg)" },
        { "transform": "rotate(0deg)" }
      ],
      "options": { "duration": 320, "easing": "soft", "fill": "both" }
    }
  ]
}
