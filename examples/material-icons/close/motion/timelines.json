{
  "intro": [
    {
      "target": "glyph",
      "at": 0,
      "keyframes": [
        { "opacity": 0, "transform": "rotate(-90deg) scale(0.9)" },
        { "opacity": 1, "transform": "rotate(0deg) scale(1)" }
      ],
      "options": {
        "duration": 460,
        "easing": "emphasized",
        "fill": "both"
      }
    }
  ],
  "hover": [
    {
      "target": "glyph",
      "at": 0,
      "keyframes": [
        { "transform": "rotate(0deg)" },
        { "transform": "rotate(90deg)" }
      ],
      "options": {
        "duration": 240,
        "easing": "emphasized",
        "fill": "both"
      }
    }
  ],
  "loadingLoop": [
    {
      "target": "glyph",
      "at": 0,
      "keyframes": [
        { "transform": "rotate(0deg)", "offset": 0, "easing": "standard" },
        { "transform": "rotate(-9deg)", "offset": 0.05, "easing": "standard" },
        { "transform": "rotate(9deg)", "offset": 0.12, "easing": "standard" },
        { "transform": "rotate(-4deg)", "offset": 0.19, "easing": "soft" },
        { "transform": "rotate(0deg)", "offset": 0.26, "easing": "linear" },
        { "transform": "rotate(0deg)", "offset": 1 }
      ],
      "options": {
        "duration": 2400,
        "easing": "linear",
        "fill": "both"
      }
    }
  ]
}
