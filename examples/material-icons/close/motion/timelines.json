{
  "intro": [
    {
      "target": "glyph",
      "at": 0,
      "keyframes": [
        { "opacity": 0, "transform": "rotate(-90deg) scale(0.9)" },
        { "opacity": 1, "transform": "rotate(0deg) scale(1)" }
      ],
      "options": {
        "duration": 460,
        "easing": "emphasized",
        "fill": "both"
      }
    }
  ],
  "hover": [
    {
      "target": "glyph",
      "at": 0,
      "keyframes": [
        { "transform": "rotate(0deg)" },
        { "transform": "rotate(90deg)" }
      ],
      "options": {
        "duration": 240,
        "easing": "emphasized",
        "fill": "both"
      }
    }
  ],
  "loadingLoop": [
    {
      "target": "glyph",
      "at": 0,
      "keyframes": [
        { "transform": "rotate(0deg)", "offset": 0 },
        { "transform": "rotate(0deg)", "offset": 0.12 },
        { "transform": "rotate(90deg)", "offset": 0.4 },
        { "transform": "rotate(90deg)", "offset": 0.6 },
        { "transform": "rotate(0deg)", "offset": 0.88 },
        { "transform": "rotate(0deg)", "offset": 1 }
      ],
      "options": {
        "duration": 2400,
        "easing": "bounceSoft",
        "fill": "both"
      }
    }
  ]
}
