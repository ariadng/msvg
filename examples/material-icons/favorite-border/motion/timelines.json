{
  "intro": [
    {
      "target": "glyph",
      "at": 0,
      "keyframes": [
        {
          "opacity": 0,
          "transform": "scale(0.7)"
        },
        {
          "opacity": 1,
          "transform": "scale(1.08)",
          "offset": 0.7,
          "easing": "soft"
        },
        {
          "opacity": 1,
          "transform": "scale(1)"
        }
      ],
      "options": {
        "duration": 500,
        "easing": "linear",
        "fill": "both"
      }
    }
  ],
  "loadingLoop": [
    {
      "target": "glyph",
      "at": 0,
      "keyframes": [
        {
          "offset": 0,
          "transform": "scale(1)",
          "easing": "emphasized"
        },
        {
          "offset": 0.06,
          "transform": "scale(1.08)",
          "easing": "soft"
        },
        {
          "offset": 0.14,
          "transform": "scale(1)",
          "easing": "emphasized"
        },
        {
          "offset": 0.2,
          "transform": "scale(1.04)",
          "easing": "soft"
        },
        {
          "offset": 0.3,
          "transform": "scale(1)",
          "easing": "linear"
        },
        {
          "offset": 1,
          "transform": "scale(1)"
        }
      ],
      "options": {
        "duration": 2600,
        "easing": "linear",
        "fill": "both"
      }
    }
  ],
  "hover": [
    {
      "target": "glyph",
      "at": 0,
      "keyframes": [
        {
          "transform": "scale(1)"
        },
        {
          "transform": "scale(1.08)",
          "offset": 0.5,
          "easing": "bounceSoft"
        },
        {
          "transform": "scale(1)"
        }
      ],
      "options": {
        "duration": 460,
        "easing": "linear",
        "fill": "both"
      }
    }
  ]
}
