{
  "intro": [
    {
      "target": "glyph",
      "at": 0,
      "keyframes": [
        {
          "opacity": 0,
          "transform": "scale(0.92)"
        },
        {
          "opacity": 1,
          "transform": "scale(1)"
        }
      ],
      "options": {
        "duration": 420,
        "easing": "linear",
        "fill": "both"
      }
    }
  ],
  "loadingLoop": [
    {
      "target": "glyph",
      "at": 0,
      "keyframes": [
        {
          "offset": 0,
          "transform": "scaleY(1)",
          "easing": "soft"
        },
        {
          "offset": 0.03,
          "transform": "scaleY(1)",
          "easing": "standard"
        },
        {
          "offset": 0.06,
          "transform": "scaleY(0.12)",
          "easing": "standard"
        },
        {
          "offset": 0.1,
          "transform": "scaleY(1)",
          "easing": "soft"
        },
        {
          "offset": 1,
          "transform": "scaleY(1)"
        }
      ],
      "options": {
        "duration": 2800,
        "easing": "linear",
        "fill": "both"
      }
    },
    {
      "target": "pupil",
      "at": 0,
      "keyframes": [
        {
          "offset": 0,
          "transform": "translateX(0px)",
          "easing": "linear"
        },
        {
          "offset": 0.2,
          "transform": "translateX(0px)",
          "easing": "soft"
        },
        {
          "offset": 0.28,
          "transform": "translateX(-16px)",
          "easing": "soft"
        },
        {
          "offset": 0.42,
          "transform": "translateX(16px)",
          "easing": "soft"
        },
        {
          "offset": 0.52,
          "transform": "translateX(0px)",
          "easing": "standard"
        },
        {
          "offset": 1,
          "transform": "translateX(0px)"
        }
      ],
      "options": {
        "duration": 2800,
        "easing": "linear",
        "fill": "both"
      }
    }
  ],
  "hover": [
    {
      "target": "glyph",
      "at": 0,
      "keyframes": [
        {
          "transform": "scaleY(1)"
        },
        {
          "transform": "scaleY(0.12)",
          "offset": 0.4,
          "easing": "standard"
        },
        {
          "transform": "scaleY(1)"
        }
      ],
      "options": {
        "duration": 420,
        "easing": "linear",
        "fill": "both"
      }
    }
  ]
}
