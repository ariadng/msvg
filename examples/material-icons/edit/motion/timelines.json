{
  "intro": [
    {
      "target": "glyph",
      "at": 0,
      "keyframes": [
        {
          "opacity": 0,
          "transform": "scale(0.92)"
        },
        {
          "opacity": 1,
          "transform": "scale(1)"
        }
      ],
      "options": {
        "duration": 420,
        "easing": "linear",
        "fill": "both"
      }
    }
  ],
  "loadingLoop": [
    {
      "target": "glyph",
      "at": 0,
      "keyframes": [
        {
          "offset": 0,
          "transform": "translate(0px,0px) rotate(0deg)",
