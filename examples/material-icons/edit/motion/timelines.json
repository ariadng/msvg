        },
        {
          "offset": 0.06,
          "transform": "translate(12px,8px) rotate(-1.5deg)",
          "easing": "soft"
        },
        {
          "offset": 0.12,
          "transform": "translate(0px,0px) rotate(0deg)",
          "easing": "soft"
        },
        {
          "offset": 0.18,
          "transform": "translate(12px,8px) rotate(-1.5deg)",
          "easing": "soft"
        },
        {
          "offset": 0.24,
          "transform": "translate(0px,0px) rotate(0deg)",
          "easing": "soft"
        },
        {
          "offset": 0.3,
          "transform": "translate(12px,8px) rotate(-1.5deg)",
          "easing": "soft"
        },
        {
          "offset": 0.36,
          "transform": "translate(0px,0px) rotate(0deg)",
          "easing": "standard"
        },
        {
          "offset": 1,
          "transform": "translate(0px,0px) rotate(0deg)"
        }
      ],
      "options": {
        "duration": 2400,
        "easing": "linear",
        "fill": "both"
      }
    }
  ],
  "hover": [
    {
      "target": "glyph",
      "at": 0,
      "keyframes": [
        {
          "transform": "translate(0px,0px) rotate(0deg)"
        },
        {
          "transform": "translate(12px,8px) rotate(-1.5deg)",
          "offset": 0.5,
          "easing": "soft"
        },
        {
          "transform": "translate(0px,0px) rotate(0deg)"
        }
      ],
      "options": {
        "duration": 460,
        "easing": "linear",
        "fill": "both"
      }
    }
  ]
