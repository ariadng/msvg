{
  "intro": [
    {
      "target": "glyph",
      "at": 0,
      "keyframes": [
        { "opacity": 0, "transform": "scale(0.6)" },
        { "opacity": 1, "transform": "scale(1.12)", "offset": 0.7 },
        { "opacity": 1, "transform": "scale(1)" }
      ],
      "options": { "duration": 500, "easing": "bounceSoft", "fill": "both" }
    }
  ],
  "loadingLoop": [
    {
      "target": "glyph",
      "at": 0,
      "keyframes": [
        { "transform": "scale(1)", "offset": 0, "easing": "emphasized" },
        { "transform": "scale(1.12)", "offset": 0.06, "easing": "soft" },
        { "transform": "scale(1)", "offset": 0.16, "easing": "emphasized" },
        { "transform": "scale(1.06)", "offset": 0.22, "easing": "soft" },
        { "transform": "scale(1)", "offset": 0.32, "easing": "linear" },
        { "transform": "scale(1)", "offset": 1 }
      ],
      "options": { "duration": 2000, "easing": "linear", "fill": "both" }
    }
  ],
  "hover": [
    {
      "target": "glyph",
      "at": 0,
      "keyframes": [
        { "transform": "scale(1)" },
        { "transform": "scale(1.12)" },
        { "transform": "scale(1)" }
      ],
      "options": { "duration": 420, "easing": "bounceSoft", "fill": "both" }
    }
  ]
}
