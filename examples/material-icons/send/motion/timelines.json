{
  "intro": [
    {
      "target": "glyph",
      "at": 0,
      "keyframes": [
        {
          "opacity": 0,
          "transform": "translateY(-10px) scale(0.94)"
        },
        {
          "opacity": 1,
          "transform": "translateY(0px) scale(1)"
        }
      ],
      "options": {
        "duration": 420,
        "easing": "standard",
        "fill": "both"
      }
    }
  ],
  "loadingLoop": [
    {
      "target": "glyph",
      "at": 0,
      "keyframes": [
        {
          "offset": 0,
          "transform": "translate(0px,0px) rotate(0deg)",
          "opacity": "1",
          "easing": "linear"
        },
        {
          "offset": 0.06,
          "transform": "translate(0px,0px) rotate(0deg)",
          "easing": "standard"
        },
        {
          "offset": 0.22,
          "transform": "translate(-18px,8px) rotate(2deg)",
          "easing": "soft"
        },
        {
          "offset": 0.34,
          "transform": "translate(50px,-22px) rotate(-4deg)",
          "easing": "emphasized"
        },
        {
          "offset": 0.52,
          "transform": "translate(0px,0px) rotate(0deg)",
          "easing": "soft"
        },
        {
          "offset": 1,
          "transform": "translate(0px,0px) rotate(0deg)"
        }
      ],
      "options": {
        "duration": 2400,
        "easing": "linear",
        "fill": "both"
      }
    }
  ],
  "hover": [
    {
      "target": "glyph",
      "at": 0,
      "keyframes": [
        {
          "offset": 0,
          "transform": "translate(0px,0px) rotate(0deg)",
          "easing": "soft"
        },
        {
          "offset": 0.5,
          "transform": "translate(24px,-11px) rotate(-3deg)",
          "easing": "soft"
        },
        {
          "offset": 1,
          "transform": "translate(0px,0px) rotate(0deg)"
        }
      ],
      "options": {
        "duration": 480,
        "easing": "linear",
        "fill": "both"
      }
    }
  ]
}
