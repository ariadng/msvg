{
  "intro": [
    {
      "target": "glyph",
      "at": 0,
      "keyframes": [
        { "opacity": 0, "transform": "translateY(-8px) scale(0.9)" },
        { "opacity": 1, "transform": "translateY(0) scale(1)" }
      ],
      "options": { "duration": 400, "easing": "soft", "fill": "both" }
    }
  ],

  "loadingLoop": [
    {
      "target": "bell",
      "at": 0,
      "keyframes": [
        { "offset": 0,    "transform": "rotate(0deg)",  "easing": "soft" },
        { "offset": 0.10, "transform": "rotate(12deg)", "easing": "soft" },
        { "offset": 0.22, "transform": "rotate(-9deg)", "easing": "soft" },
        { "offset": 0.34, "transform": "rotate(5deg)",  "easing": "soft" },
        { "offset": 0.44, "transform": "rotate(-2deg)", "easing": "soft" },
        { "offset": 0.52, "transform": "rotate(0deg)",  "easing": "linear" },
        { "offset": 1,    "transform": "rotate(0deg)" }
      ],
      "options": { "duration": 2400, "easing": "linear", "fill": "both" }
    }
  ],

  "hover": [
    {
      "target": "bell",
      "at": 0,
      "keyframes": [
        { "offset": 0,    "transform": "rotate(0deg)",  "easing": "soft" },
        { "offset": 0.22, "transform": "rotate(12deg)", "easing": "soft" },
        { "offset": 0.48, "transform": "rotate(-8deg)", "easing": "soft" },
        { "offset": 0.72, "transform": "rotate(4deg)",  "easing": "soft" },
        { "offset": 1,    "transform": "rotate(0deg)" }
      ],
      "options": { "duration": 640, "easing": "linear", "fill": "both" }
    }
  ]
}
