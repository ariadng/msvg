{
  "intro": [
    {
      "target": "glyph",
      "at": 0,
      "keyframes": [
        {
          "opacity": 0,
          "transform": "translateY(-10px) scale(0.94)"
        },
        {
          "opacity": 1,
          "transform": "translateY(0px) scale(1)"
        }
      ],
      "options": {
        "duration": 420,
        "easing": "standard",
        "fill": "both"
      }
    }
  ],
  "loadingLoop": [
    {
      "target": "personLeft",
      "at": 0,
      "keyframes": [
        {
          "offset": 0,
          "transform": "rotate(0deg)",
          "easing": "soft"
        },
        {
          "offset": 0.14,
          "transform": "rotate(3deg)",
          "easing": "soft"
        },
        {
          "offset": 0.3,
          "transform": "rotate(0deg)",
          "easing": "soft"
        },
        {
          "offset": 1,
          "transform": "rotate(0deg)"
        }
      ],
      "options": {
        "duration": 2200,
        "easing": "linear",
        "fill": "both"
      }
    },
    {
      "target": "personRight",
      "at": 0,
      "keyframes": [
        {
          "offset": 0,
          "transform": "rotate(0deg)",
          "easing": "soft"
        },
        {
          "offset": 0.14,
          "transform": "rotate(-3deg)",
          "easing": "soft"
        },
        {
          "offset": 0.3,
          "transform": "rotate(0deg)",
          "easing": "soft"
        },
        {
          "offset": 1,
          "transform": "rotate(0deg)"
        }
      ],
      "options": {
        "duration": 2200,
        "easing": "linear",
        "fill": "both"
      }
    }
  ],
  "hover": [
    {
      "target": "glyph",
      "at": 0,
      "keyframes": [
        {
          "offset": 0,
          "transform": "scale(1)",
          "easing": "soft"
        },
        {
          "offset": 0.5,
          "transform": "scale(1.04)",
          "easing": "soft"
        },
        {
          "offset": 1,
          "transform": "scale(1)"
        }
      ],
      "options": {
        "duration": 220,
        "easing": "linear",
        "fill": "both"
      }
    }
  ]
}
