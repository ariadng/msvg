        },
        {
          "transform": "translateY(0px) scale(0.99)",
          "offset": 0.32,
          "easing": "soft"
        },
        {
          "transform": "translateY(0px) scale(1)",
          "offset": 0.4,
          "easing": "linear"
        },
        {
          "transform": "translateY(0px) scale(1)",
          "offset": 1
        }
