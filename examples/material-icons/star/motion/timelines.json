{
  "intro": [
    {
      "target": "glyph",
      "at": 0,
      "keyframes": [
        { "opacity": 0, "transform": "rotate(-40deg) scale(0.5)" },
        { "opacity": 1, "transform": "rotate(0deg) scale(1)" }
      ],
      "options": { "duration": 520, "easing": "bounceSoft", "fill": "both" }
    }
  ],
  "loadingLoop": [
    {
      "target": "glyph",
      "at": 0,
      "keyframes": [
        { "offset": 0,    "transform": "rotate(0deg) scale(1)",     "easing": "soft" },
        { "offset": 0.32, "transform": "rotate(-8deg) scale(1)",    "easing": "emphasized" },
        { "offset": 0.40, "transform": "rotate(12deg) scale(1.08)", "easing": "standard" },
        { "offset": 0.48, "transform": "rotate(0deg) scale(1)",     "easing": "linear" },
        { "offset": 1,    "transform": "rotate(0deg) scale(1)" }
      ],
      "options": { "duration": 2600, "easing": "linear", "fill": "both" }
    }
  ],
  "hover": [
    {
      "target": "glyph",
      "at": 0,
      "keyframes": [
        { "transform": "rotate(0deg) scale(1)" },
        { "transform": "rotate(-8deg) scale(1.12)" },
        { "transform": "rotate(0deg) scale(1)" }
      ],
      "options": { "duration": 460, "easing": "bounceSoft", "fill": "both" }
    }
  ]
}
