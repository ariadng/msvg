        {
          "offset": 1,
          "transform": "scale(1)"
        }
      ],
      "options": {
        "duration": 2600,
        "easing": "linear",
        "fill": "both"
      }
    }
  ],
  "hover": [
    {
      "target": "textTop",
      "at": 0,
