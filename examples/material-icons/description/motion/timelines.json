          "transform": "scale(0.94)"
        },
        {
          "opacity": 1,
          "transform": "scale(1)"
        }
      ],
      "options": {
        "duration": 420,
        "easing": "linear",
        "fill": "both"
      }
    }
  ],
  "loadingLoop": [
