        {
          "offset": 0.16,
          "transform": "scale(1)",
          "easing": "soft"
        },
        {
          "offset": 0.23,
          "transform": "scale(1.12)",
          "easing": "soft"
        },
        {
          "offset": 0.33,
          "transform": "scale(1)",
