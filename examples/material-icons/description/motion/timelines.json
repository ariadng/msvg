          "transform": "scale(1.12)",
          "easing": "soft"
        },
        {
          "offset": 0.25,
          "transform": "scale(1)",
          "easing": "standard"
        },
        {
          "offset": 1,
          "transform": "scale(1)"
        }
      ],
      "options": {
        "duration": 2600,
        "easing": "linear",
        "fill": "both"
      }
    },
    {
      "target": "textBottom",
      "at": 0,
      "keyframes": [
        {
          "offset": 0,
          "transform": "scale(1)",
          "easing": "linear"
